{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/game/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "game-engine-api",
          "Port": 5001
        }
      ],
      "UpstreamPathTemplate": "/api/game/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "Priority": 1
    },
    {
      "DownstreamPathTemplate": "/api/logs/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "log-service-api",
          "Port": 5002
        }
      ],
      "UpstreamPathTemplate": "/api/logs/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "Priority": 1
    },
    {
      "DownstreamPathTemplate": "/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "game-engine-api",
          "Port": 5001
        }
      ],
      "UpstreamPathTemplate": "/health/game-engine",
      "UpstreamHttpMethod": [ "GET" ],
      "Priority": 2
    },
    {
      "DownstreamPathTemplate": "/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "log-service-api",
          "Port": 5002
        }
      ],
      "UpstreamPathTemplate": "/health/log-service",
      "UpstreamHttpMethod": [ "GET" ],
      "Priority": 2
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://api-gateway:5000",
    "RequestIdKey": "X-Request-Id",
    "DownstreamScheme": "http"
  }
}
