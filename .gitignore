# =============================================================
# .gitignore — Mundo de Wumpus
# =============================================================

# ---------------------------------------------------------------
# Carpetas de IA / Asistentes (NO SUBIR NUNCA)
# ---------------------------------------------------------------
.claude/
.codex/
.cursor/
.copilot/
.github/copilot*/
.github/copilot-instructions.md
CLAUDE.md
AGENTS.md
**/CLAUDE.md
**/AGENTS.md

# ---------------------------------------------------------------
# Build artifacts — .NET
# ---------------------------------------------------------------
**/bin/
**/obj/
**/Debug/
**/Release/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# ---------------------------------------------------------------
# Build artifacts — C++ (legacy)
# ---------------------------------------------------------------
build/
*.o
*.obj
*.exe
*.out
*.app

# ---------------------------------------------------------------
# Node.js / Angular
# ---------------------------------------------------------------
node_modules/
dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.angular/

# ---------------------------------------------------------------
# IDE / Editores
# ---------------------------------------------------------------
.vs/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------
# Docker
# ---------------------------------------------------------------
docker-compose.override.yml
.env
.env.*

# ---------------------------------------------------------------
# Paquetes NuGet
# ---------------------------------------------------------------
**/packages/
*.nupkg
**/.nuget/

# ---------------------------------------------------------------
# Archivos de cobertura / testing
# ---------------------------------------------------------------
coverage/
*.lcov
TestResults/
*.testresults

# ---------------------------------------------------------------
# Variables de entorno y secretos
# ---------------------------------------------------------------
appsettings.*.json
!appsettings.json
!appsettings.Development.json
*.secret
secrets.json

# ---------------------------------------------------------------
# Archivos temporales
# ---------------------------------------------------------------
*.tmp
*.temp
*.cache
*.pid
